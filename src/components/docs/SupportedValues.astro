---
import { schemaDefinitionUrl, type SupportedValueGroup } from '../../data/supported-values';
interface Props {
  groups: SupportedValueGroup[];
  documentSchemas?: string[];
}
const { groups, documentSchemas = [] } = Astro.props;
---

{
  (groups.length > 0 || documentSchemas.length > 0) && (
    <section
      class="docs-supported-values mt-12 border-t border-[var(--color-border)] pt-8"
      aria-labelledby="supported-values-heading"
    >
      <div class="flex flex-wrap items-start justify-between gap-4">
        <h2 id="supported-values-heading" class="text-2xl font-semibold text-[var(--color-text-strong)]">
          Schemas and supported values
        </h2>
        <div class="flex max-w-xl flex-wrap justify-end gap-x-4 gap-y-2">
          {documentSchemas.map((schema) => (
            <a
              href={`/schema/v1.0/${schema}.schema.json`}
              target="_blank"
              rel="noreferrer"
              class="text-sm font-medium text-[var(--color-accent)] hover:underline"
            >
              {schema}.schema.json ↗
            </a>
          ))}
        </div>
      </div>
      <div class="mt-6 space-y-6">
        {groups.map((group) => (
          <div>
            <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
              <h3 class="text-lg font-semibold text-[var(--color-text-strong)]">{group.label}</h3>
              <code class="text-sm">{group.field}</code>
              <a
                href={schemaDefinitionUrl(group.definition)}
                target="_blank"
                rel="noreferrer"
                class="text-xs font-medium text-[var(--color-accent)] hover:underline"
              >
                Definition ↗
              </a>
            </div>
            <p class="mt-1 text-sm text-[var(--color-text-muted)]">
              {group.description}{' '}
              {group.closed === false
                ? 'This is an open recommendation list.'
                : 'Values outside this closed list are invalid.'}
            </p>
            <div class="mt-3 flex flex-wrap gap-2">
              {group.values.map((value) => (
                <code class="rounded-md bg-[var(--color-surface-muted)] px-2 py-1 text-sm">{value}</code>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  )
}
